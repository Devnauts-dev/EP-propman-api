# Server
NODE_ENV=development
PORT=5050

# PostgreSQL (app uses only this URL)
DATABASE_URL="postgresql://postgres:your_password@localhost:5433/ecommerce_db?schema=public"

# Postgres container only (for docker-compose.postgres.yml and docker-compose.yml)
POSTGRES_DB=ecommerce_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
