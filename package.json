{
  "name": "devops-practice",
  "version": "1.0.0",
  "description": "EP PropMan Auth API backend with Express, PostgreSQL and Prisma",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "cross-env NODE_ENV=development node --watch src/server.js",
    "prod": "cross-env NODE_ENV=production node src/server.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "test": "cross-env NODE_ENV=test DATABASE_URL=postgresql://postgres:password@localhost:5432/ep_propman?schema=test JWT_ACCESS_SECRET=test_access_secret JWT_REFRESH_SECRET=test_refresh_secret jest --runInBand",
    "test:watch": "npm run test -- --watch",
    "deploy": "docker compose up -d --build backend",
    "deploy:migrate": "docker compose exec backend npx prisma migrate deploy",
    "logs": "docker logs backend -f"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idreesahmed1257/DevOps-Practice.git"
  },
  "keywords": [
    "express",
    "postgresql",
    "prisma",
    "property-management",
    "auth",
    "rbac",
    "rest-api"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/idreesahmed1257/DevOps-Practice/issues"
  },
  "homepage": "https://github.com/idreesahmed1257/DevOps-Practice#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "prisma": "^7.4.1",
    "supertest": "^7.1.4"
  }
}
